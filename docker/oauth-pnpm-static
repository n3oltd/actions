# oauth-pnpm-static — oauth2-proxy serving a static site built out of a pnpm
# workspace package.
#
#   /*  ->  the built site (static, /var/www)
#
# Build-args:
#   PACKAGE       workspace package whose build script emits the site
#   BUILD_SCRIPT  package script to run (default: build)
#   OUTPUT_DIR    context-relative path of the built static output

ARG PACKAGE
ARG BUILD_SCRIPT=build
ARG OUTPUT_DIR

########################
### oauth2-proxy binary (pinned; bump deliberately)
########################
FROM quay.io/oauth2-proxy/oauth2-proxy:v7.15.3 AS oauth2proxy

########################
### build the site
########################
FROM node:24-slim AS build
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV CI=true
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable
WORKDIR /repo
COPY . .
ARG PACKAGE
ARG BUILD_SCRIPT
# The workspace lockfile can reference private @n3oltd GitHub Packages, which the
# supply-chain check resolves for every entry. The committed .npmrc only maps the
# scope to the registry; pnpm needs a literal auth token, written for this RUN only
# (the build stage is not the pushed image, and the token is restored out again).
RUN --mount=type=secret,id=github_token,required=true sh -eu -c '\
  touch .npmrc && cp .npmrc .npmrc.bak && \
  printf "\n//npm.pkg.github.com/:_authToken=%s\n" "$(cat /run/secrets/github_token)" >> .npmrc && \
  pnpm install --frozen-lockfile --filter "${PACKAGE}..." && \
  mv .npmrc.bak .npmrc'
RUN pnpm --filter "${PACKAGE}" run "${BUILD_SCRIPT}"

########################
### final
########################
FROM oauth2proxy AS final
ENV OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:8080
ENV OAUTH2_PROXY_UPSTREAMS=file:///var/www/#/
ARG OUTPUT_DIR
COPY --from=build /repo/${OUTPUT_DIR} /var/www
EXPOSE 8080
